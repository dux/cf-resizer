#!/usr/bin/env bun
import { resolve } from "path"
import { writeFileSync, readFileSync, existsSync } from "fs"
import { spawnSync } from "child_process"
import { createInterface } from "readline"

const configPath = resolve(process.cwd(), ".cf-resizer.yaml")

function parseYaml(text: string): Record<string, string> {
  const result: Record<string, string> = {}
  for (const line of text.split("\n")) {
    const m = line.match(/^\s*([^#:\s]+)\s*:\s*(.+?)\s*$/)
    if (m) result[m[1]] = m[2].replace(/^["']|["']$/g, "")
  }
  return result
}

function prompt(question: string, fallback = ""): Promise<string> {
  const rl = createInterface({ input: process.stdin, output: process.stdout })
  const hint = fallback ? ` [${fallback}]` : ""
  return new Promise((resolve) => {
    rl.question(`${question}${hint}: `, (answer) => {
      rl.close()
      resolve(answer.trim() || fallback)
    })
  })
}

function confirm(question: string): Promise<boolean> {
  const rl = createInterface({ input: process.stdin, output: process.stdout })
  return new Promise((resolve) => {
    rl.question(`${question} [Y/n] `, (answer) => {
      rl.close()
      resolve(!answer.trim() || answer.trim().toLowerCase() === "y")
    })
  })
}

// --- Step 1: Create or update config ---
let config: Record<string, string> = {}

if (existsSync(configPath)) {
  config = parseYaml(readFileSync(configPath, "utf8"))
  console.log("Found .cf-resizer.yaml")
}

config.domain = await prompt("Domain", config.domain || "")
config.secret = await prompt("Admin secret", config.secret || "")
config.bucket = await prompt("R2 bucket name", config.bucket || "")
config.max_size = await prompt("Max size (px)", config.max_size || "1600")

if (!config.domain || !config.secret || !config.bucket) {
  console.error("domain, secret, and bucket are required")
  process.exit(1)
}

// Show config and confirm
console.log(`\n  domain:    ${config.domain}`)
console.log(`  secret:    ${config.secret}`)
console.log(`  bucket:    ${config.bucket}`)
console.log(`  max_size: ${config.max_size}\n`)

if (!await confirm("Continue with this config?")) {
  console.log("Aborted")
  process.exit(0)
}

// Write config
const yaml = `domain: ${config.domain}\nsecret: ${config.secret}\nbucket: ${config.bucket}\nmax_size: ${config.max_size}\n`
writeFileSync(configPath, yaml)
console.log(`Saved ${configPath}`)

// --- Step 2: DNS ---
const { domain, bucket } = config
const zone = domain.split(".").slice(-2).join(".")
const subdomain = domain.split(".").slice(0, -2).join(".")

console.log(`Creating DNS A record for ${domain}...`)
const dns = spawnSync("flarectl", [
  "dns", "create",
  "--zone", zone,
  "--type", "A",
  "--name", subdomain || "@",
  "--content", "192.0.2.1",
  "--proxy",
], { stdio: "pipe" })

if (dns.status === 0) {
  console.log("DNS record created")
} else {
  const err = dns.stderr?.toString() || ""
  if (err.includes("already exists") || err.includes("81058")) {
    console.log("DNS record already exists")
  } else {
    console.log("DNS error:", err.trim())
  }
}

// --- Step 3: R2 bucket ---
// cf-deploy generates toml and wrangler env, reuse them
const { tomlPath, wranglerEnv } = await import("./cf-deploy")

const listBuckets = spawnSync("npx", ["wrangler", "r2", "bucket", "list", "--config", tomlPath], {
  stdio: "pipe",
  env: wranglerEnv,
})
const bucketList = listBuckets.stdout?.toString() || ""
if (bucketList.includes(bucket)) {
  console.log(`R2 bucket "${bucket}" exists`)
} else {
  console.log(`Creating R2 bucket "${bucket}"...`)
  const r2 = spawnSync("npx", ["wrangler", "r2", "bucket", "create", bucket, "--config", tomlPath], {
    stdio: "inherit",
    env: wranglerEnv,
  })
  if (r2.status !== 0) {
    console.error("Failed to create R2 bucket")
    process.exit(1)
  }
}

// --- Step 4: Deploy ---
const { deploy } = await import("./cf-deploy")
deploy()
